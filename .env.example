# ============================================================
# Windmill — environment configuration
# Copy to .env and fill in values before starting workers.
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSLMODE=prefer           # prefer | require | disable

# ------------------------------------------------------------
# Message queue (RabbitMQ)
# ------------------------------------------------------------
QUEUE_HOST=
QUEUE_PORT=5672             # 5671 for TLS
QUEUE_USER=
QUEUE_PASSWORD=
QUEUE_SSL=false             # true for TLS connections
QUEUE_MESSAGE_TTL_MS=       # optional; omit to disable TTL

# ------------------------------------------------------------
# Image transport/storage
# ------------------------------------------------------------
# IMAGE_STORE_MODE:
#   inline = current behavior; embed image bytes in RabbitMQ messages
#   valkey = store image bytes in Valkey and pass refs through RabbitMQ
IMAGE_STORE_MODE=inline
VALKEY_HOST=
VALKEY_PORT=6379
VALKEY_SSL=true
VALKEY_USERNAME=
VALKEY_PASSWORD=
VALKEY_CA_CERTS=/etc/ssl/certs/ca-certificates.crt
VALKEY_IMAGE_TTL_SECONDS=90
VALKEY_CROP_TTL_SECONDS=90
VALKEY_SOCKET_CONNECT_TIMEOUT_SECONDS=3
VALKEY_SOCKET_TIMEOUT_SECONDS=3
VALKEY_HEALTH_CHECK_INTERVAL_SECONDS=30
VALKEY_KEEPALIVE_PING_SECONDS=15

# RabbitMQ consumer connection liveness. TCP keepalive is useful when TLS
# connections sit idle behind load balancers or network middleboxes.
QUEUE_TCP_KEEPALIVE=true
QUEUE_TCP_KEEPIDLE_SECONDS=60
QUEUE_TCP_KEEPINTVL_SECONDS=15
QUEUE_TCP_KEEPCNT=4

# ------------------------------------------------------------
# API gateway (api.py)
# ------------------------------------------------------------
API_PORT=9999
API_DEBUG=false
MAX_IMAGE_DIMENSION=2048    # longest edge in pixels; images resized in-memory
SERVICE_CONFIG_PATH=service_config.yaml

# ------------------------------------------------------------
# Worker tuning
# ------------------------------------------------------------
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
WORKER_PREFETCH_COUNT=1
WORKER_HEARTBEAT_INTERVAL=30
REQUEST_TIMEOUT=30          # seconds; ML service HTTP call timeout
MAX_RETRIES=3
RETRY_DELAY=5               # seconds between retries

# ------------------------------------------------------------
# Service-specific tuning (optional overrides)
# ------------------------------------------------------------
HARMONY_USE_HIGHEST_CONFIDENCE=true
REMBG_TIMEOUT=60
CAPTION_SYNTHESIS_MODEL=    # override default qwen model for caption_summary
DLQ_POLL_INTERVAL=5.0       # seconds between full DLQ sweeps
